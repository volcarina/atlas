{
  "name": "@atlas/backend",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "ts-node-dev --rs src/index.ts",
    "types": "tsc --noEmit --project ./tsconfig.json",
    "build": "rimraf ./dist && tsc --build ./tsconfig.json",
    "start": "node ./dist/index.js",
    "prettify": "prettier --log-level warn --ignore-path './.prettierignore --cache --write '{src/**/*,*}.{ts,tsx,js,json,yml,scss}'"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.3.0"
  },
  "dependencies": {
    "@trpc/server": "^11.11.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "lodash": "^4.17.23",
    "zod": "^4.3.6"
  }
}
